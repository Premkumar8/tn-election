{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tnelection.onrender.com/api/:path*"
    },
    {
      "source": "/webhook/:path*",
      "destination": "https://tnelection.onrender.com/webhook/:path*"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    }
  ]
}
